{
  "ConnectionStrings": {
    "Default": "Server=localhost;Port=5432;User Id=dev;Password=dev;Database=erp_project;Pooling=true;MinPoolSize=1;MaxPoolSize=100;CommandTimeout=120;Timeout=120;KeepAlive=120;"
  },

  "Jwt": {
    "Key": "${JWT_SIGNING_KEY}",
    "Issuer": "webvella-erp",
    "Audience": "webvella-erp"
  },

  "Jobs": {
    "Enabled": true,
    "PollingIntervalSeconds": 1
  },

  "Messaging": {
    "Transport": "RabbitMQ",
    "RabbitMQ": {
      "Host": "rabbitmq",
      "Port": 5672,
      "Username": "guest",
      "Password": "guest"
    }
  },

  "Redis": {
    "ConnectionString": "redis:6379"
  },

  "ServiceUrls": {
    "CoreService": "http://core-service:8080",
    "CrmService": "http://crm-service:8080"
  },

  "Grpc": {
    "CoreServiceUrl": "http://core-service:8081",
    "CrmServiceUrl": "http://crm-service:8081"
  },

  "Eql": {
    "QueryTimeoutSeconds": 600
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },

  "AllowedHosts": "*",

  "Lang": "en",
  "Locale": "en-US",
  "TimeZoneName": "FLE Standard Time",

  "EncryptionKey": "${ENCRYPTION_KEY}",

  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:8080",
        "Protocols": "Http1AndHttp2"
      },
      "Grpc": {
        "Url": "http://0.0.0.0:8081",
        "Protocols": "Http2"
      }
    }
  }
}
