<Project Sdk="Microsoft.NET.Sdk.Web">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<AssemblyName>WebVella.Erp.Service.Project</AssemblyName>
		<RootNamespace>WebVella.Erp.Service.Project</RootNamespace>
		<SatelliteResourceLanguages>en</SatelliteResourceLanguages>
		<DockerDefaultTargetOS>Linux</DockerDefaultTargetOS>
		<Nullable>disable</Nullable>
		<ImplicitUsings>disable</ImplicitUsings>
	</PropertyGroup>

	<ItemGroup>
		<!-- Preserved from source csproj — ASP.NET Core MVC Newtonsoft.Json integration for API contract backward compatibility -->
		<PackageReference Include="Microsoft.AspNetCore.Mvc.NewtonsoftJson" />
		<!-- JWT Bearer authentication for validating tokens propagated from API Gateway -->
		<PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" />
		<!-- gRPC server hosting for inter-service communication -->
		<PackageReference Include="Grpc.AspNetCore" />
		<!-- Google.Protobuf: CPM pins 3.29.3, but Grpc.AspNetCore 2.71.0 requires >= 3.30.2 -->
		<PackageReference Include="Google.Protobuf" VersionOverride="3.30.2" />
		<!-- Build-time protobuf/gRPC code generation tooling -->
		<PackageReference Include="Grpc.Tools" PrivateAssets="All" />
		<!-- Message bus abstraction for event-driven architecture replacing hook-based communication -->
		<PackageReference Include="MassTransit" />
		<!-- RabbitMQ transport for MassTransit message bus -->
		<PackageReference Include="MassTransit.RabbitMQ" />
		<!-- Distributed Redis caching replacing in-process IMemoryCache -->
		<PackageReference Include="Microsoft.Extensions.Caching.StackExchangeRedis" />
		<!-- EF Core PostgreSQL provider for database-per-service model -->
		<PackageReference Include="Npgsql.EntityFrameworkCore.PostgreSQL" />
		<!-- EF Core design-time migration tooling for converting plugin patch system to EF migrations -->
		<PackageReference Include="Microsoft.EntityFrameworkCore.Design">
			<PrivateAssets>all</PrivateAssets>
			<IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
		</PackageReference>
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\..\SharedKernel\WebVella.Erp.SharedKernel\WebVella.Erp.SharedKernel.csproj" />
		<ProjectReference Include="..\WebVella.Erp.Service.Core\WebVella.Erp.Service.Core.csproj" />
	</ItemGroup>

	<!-- gRPC Protobuf Definitions — Server-side code generation -->
	<ItemGroup>
		<Protobuf Include="../../../proto/project.proto" GrpcServices="Server" ProtoRoot="../../../proto" />
		<Protobuf Include="../../../proto/common.proto" GrpcServices="None" ProtoRoot="../../../proto" />
	</ItemGroup>

</Project>
