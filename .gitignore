# =============================================================================
# WebVella ERP — Nx Monorepo .gitignore
# =============================================================================
# Comprehensive ignore rules for the serverless microservices monorepo:
#   - Nx workspace (apps/, services/, libs/, infra/)
#   - React 19 SPA (Vite 6, Tailwind CSS 4)
#   - .NET 9 Lambda services (Native AOT)
#   - Node.js 22 Lambda authorizer
#   - AWS CDK 2.x infrastructure
#   - LocalStack development environment
# =============================================================================

# =============================================================================
# Dependencies
# =============================================================================
node_modules/
**/packages/*
!**/packages/build/

# =============================================================================
# Build Outputs
# =============================================================================
dist/
build/
*.js.map
*.d.ts
!libs/*/src/**/*.d.ts
tmp/
artifacts/

# =============================================================================
# .NET Build Outputs
# =============================================================================
**/bin/
**/obj/
*.nupkg
*.snupkg
**/[Dd]ebug/
**/[Dd]ebugPublic/
**/[Rr]elease/
**/[Rr]eleases/
x64/
x86/
bld/
*.ilk
*.pdb
*.pgc
*.pgd
*.rsp
*.sbr
*.tlb
*.tli
*.tlh
*.tmp_proj
*.pch
*.meta
*.obj

# =============================================================================
# LocalStack
# =============================================================================
.localstack/
volume/
localstack/

# =============================================================================
# Environment Files
# =============================================================================
*.env
.env.*
.env.local
.env.*.local

# =============================================================================
# Terraform / CDK State
# =============================================================================
*.tfstate
*.tfstate.*
cdk.out/
cdk-outputs.json

# =============================================================================
# IDE — Visual Studio / VS Code / JetBrains
# =============================================================================
.idea/
.vscode/
.vs/
*.suo
*.ntvs*
*.njsproj
*.sln.docstats
*.sln.docstates
*.swp
*.user
*.userosscache
*.userprefs
*.DotSettings.user
*.sln.ide

# =============================================================================
# OS Files
# =============================================================================
.DS_Store
Thumbs.db
~$*
*~

# =============================================================================
# Test & Coverage
# =============================================================================
coverage/
test-results/
playwright-report/
TestResult.xml
*.VisualState.xml
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# =============================================================================
# Logs
# =============================================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =============================================================================
# Nx
# =============================================================================
.nx/cache
.nx/workspace-data

# =============================================================================
# .NET Tooling & Profiling
# =============================================================================
_ReSharper*/
*.[Rr]e[Ss]harper
*.dotCover
_NCrunch_*
.*crunch*.local.xml
nCrunchTemp_*
_TeamCity*
.JustCode
*.mm.*
AutoTest.Net/
*.gpState
*.pidb
*.svclog
*.scc
*.vspscc
*.vssscc
.builds
FakesAssemblies/
.ntvs_analysis.dat
*.plg
*.opt
_Chutzpah*
ipch/
*.aps
*.ncb
*.opensdf
*.sdf
*.cachefile
*.psess
*.vsp
*.vspx
*.sap
$tf/

# =============================================================================
# Publishing & Deployment
# =============================================================================
publish/
*.[Pp]ublish.xml
*.azurePubxml
*.pubxml
*.publishproj
AppPackages/
csx/
*.build.csdef

# =============================================================================
# Project & Solution Artifacts
# =============================================================================
project.lock.json
ClientBin/
[Ss]tyle[Cc]op.*
*.dbmdl
*.dbproj.schemaview
*.pfx
*.publishsettings
Generated_Code/
_UpgradeReport_Files/
Backup*/
UpgradeLog*.XML
UpgradeLog*.htm
orleans.codegen.cs
dlldata.c
*_i.c
*_p.c
*_i.h
_Pvt_Extensions

# =============================================================================
# Cache Files
# =============================================================================
*.[Cc]ache
!*.[Cc]ache/
.sass-cache/

# =============================================================================
# Database Files
# =============================================================================
*.mdf
*.ldf

# =============================================================================
# Business Intelligence
# =============================================================================
*.rdl.data
*.bim.layout
*.bim_*.settings

# =============================================================================
# Visual Studio LightSwitch
# =============================================================================
**/*.HTMLClient/GeneratedArtifacts
**/*.DesktopClient/GeneratedArtifacts
**/*.DesktopClient/ModelManifest.xml
**/*.Server/GeneratedArtifacts
**/*.Server/ModelManifest.xml

# =============================================================================
# Project-Specific Ignores
# =============================================================================
**/Properties/launchSettings.json
DocProject/buildhelp/
DocProject/Help/*.HxT
DocProject/Help/*.HxC
DocProject/Help/*.hhc
DocProject/Help/*.hhk
DocProject/Help/*.hhp
DocProject/Help/Html2
DocProject/Help/html
