{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "shared-schemas",
  "sourceRoot": "libs/shared-schemas/src",
  "projectType": "library",
  "tags": ["scope:shared", "type:lib"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/shared-schemas",
        "main": "libs/shared-schemas/src/index.ts",
        "tsConfig": "libs/shared-schemas/tsconfig.lib.json",
        "assets": [
          {
            "glob": "**/*.json",
            "input": "libs/shared-schemas/src/events",
            "output": "events"
          },
          {
            "glob": "**/*.yaml",
            "input": "libs/shared-schemas/src/api",
            "output": "api"
          }
        ]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/vite:test"
    }
  }
}
