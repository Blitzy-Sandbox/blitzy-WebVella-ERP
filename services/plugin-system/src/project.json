{
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "name": "plugin-system",
  "root": "services/plugin-system",
  "sourceRoot": "services/plugin-system/src",
  "projectType": "application",
  "tags": ["type:service", "scope:plugin-system", "runtime:dotnet"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "dotnet publish ../PluginSystem.csproj -c Release -o dist/",
        "cwd": "services/plugin-system/src"
      },
      "dependsOn": ["^build"]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "dotnet test ../tests/ --configuration Release --logger trx",
        "cwd": "services/plugin-system/src"
      },
      "dependsOn": ["build"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "dotnet format ../PluginSystem.csproj --verify-no-changes",
        "cwd": "services/plugin-system/src"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "dotnet run --project ../PluginSystem.csproj",
        "cwd": "services/plugin-system/src"
      }
    },
    "deploy": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cdklocal deploy PluginSystemStack --context localstack=true --require-approval never",
        "cwd": "infra"
      },
      "dependsOn": ["build"]
    }
  }
}
