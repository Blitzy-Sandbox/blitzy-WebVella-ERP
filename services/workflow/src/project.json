{
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "name": "workflow",
  "root": "services/workflow",
  "sourceRoot": "services/workflow/src",
  "projectType": "application",
  "tags": ["scope:service", "type:backend", "domain:workflow"],
  "implicitDependencies": ["shared-schemas", "shared-utils"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/services/workflow/bin"],
      "options": {
        "command": "dotnet build",
        "cwd": "services/workflow"
      },
      "dependsOn": ["^build"]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "dotnet test",
        "cwd": "services/workflow"
      },
      "dependsOn": ["build"]
    },
    "publish": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/services/workflow/bin/Release"],
      "options": {
        "command": "dotnet publish -c Release --self-contained true -r linux-x64",
        "cwd": "services/workflow"
      },
      "dependsOn": ["build"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "dotnet format --verify-no-changes",
        "cwd": "services/workflow"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "dotnet run --project Workflow.csproj",
        "cwd": "services/workflow"
      }
    },
    "deploy": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cdklocal deploy WorkflowStack --context localstack=true --require-approval never",
        "cwd": "infra"
      },
      "dependsOn": ["publish"]
    }
  }
}
