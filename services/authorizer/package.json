{
  "name": "@webvella-erp/authorizer",
  "version": "1.0.0",
  "private": true,
  "description": "Custom Lambda JWT Authorizer for HTTP API Gateway v2 — validates Cognito JWT tokens with LocalStack fallback",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "Apache-2.0",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node22 --outdir=dist --external:@aws-sdk/*",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "jsonwebtoken": "^9.0.0",
    "jwks-rsa": "^3.1.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "esbuild": "^0.24.0"
  }
}
