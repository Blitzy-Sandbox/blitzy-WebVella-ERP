{
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "name": "identity",
  "root": "services/identity",
  "sourceRoot": "services/identity/src",
  "projectType": "application",
  "tags": ["type:service", "scope:identity", "runtime:dotnet"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "dotnet publish ../Identity.csproj -c Release -o dist/",
        "cwd": "services/identity/src"
      },
      "dependsOn": ["^build"]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "dotnet test ../tests/ --configuration Release --logger trx",
        "cwd": "services/identity/src"
      },
      "dependsOn": ["build"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "dotnet format ../Identity.csproj --verify-no-changes",
        "cwd": "services/identity/src"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "dotnet run --project ../Identity.csproj",
        "cwd": "services/identity/src"
      }
    },
    "deploy": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cdklocal deploy IdentityStack --context localstack=true --require-approval never",
        "cwd": "infra"
      },
      "dependsOn": ["build"]
    }
  }
}
