{
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "name": "file-management",
  "root": "services/file-management",
  "sourceRoot": "services/file-management/src",
  "projectType": "application",
  "tags": [
    "scope:file-management",
    "type:service",
    "runtime:dotnet"
  ],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/dist"
      ],
      "options": {
        "command": "dotnet publish ../FileManagement.csproj -c Release -o dist/",
        "cwd": "services/file-management/src"
      },
      "dependsOn": [
        "^build"
      ]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "dotnet test ../tests/ --configuration Release --logger trx",
        "cwd": "services/file-management/src"
      },
      "dependsOn": [
        "build"
      ]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "dotnet format ../FileManagement.csproj --verify-no-changes",
        "cwd": "services/file-management/src"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "dotnet run --project ../FileManagement.csproj",
        "cwd": "services/file-management/src"
      }
    },
    "deploy": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cdklocal deploy FileManagementStack --context localstack=true --require-approval never",
        "cwd": "infra"
      },
      "dependsOn": [
        "build"
      ]
    },
    "integration-test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "dotnet test ../tests/ --configuration Release --logger trx --filter \"FullyQualifiedName~Integration\"",
        "cwd": "services/file-management/src"
      },
      "dependsOn": [
        "build"
      ]
    }
  }
}
